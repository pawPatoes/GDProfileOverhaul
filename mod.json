{
	"geode": "5.6.1",
	"gd": {
		"win": "2.2081",
		"android": "2.2081",
		"mac": "2.2081",
		"ios": "2.2081"
	},
	"id": "arcticwoof.profile_overhaul",
	"name": "Profile Overhaul",
	"version": "v1.0.2",
	"developer": "ArcticWoof",
	"description": "Changes the entire Profile Page",
	"dependencies": {
		"geode.node-ids": ">=v1.23.3"
	},
	"resources": {
		"spritesheets": {
			"PO-Sheet":[
				"resources/*.png"
			]
		}
	},
	"settings": {
		"showDiamondStats":{
			"type": "bool",
			"name": "Show Diamond Stats",
			"default": false,
			"description": "Shows the user's diamond stats."
		},
		"showModSettingsButton":{
			"type": "bool",
			"name": "Show Mod Settings Button",
			"default": true,
			"description": "Shows a button on the profile page to quickly access mod settings."
		},
		"showGradientBackground": {
			"type": "bool",
			"name": "Show Gradient Background",
			"default": false,
			"description": "Shows a gradient background on the profile page using the user's profile colors. <co>Work in Progress</co>"
		}
	},
	"tags": ["enhancement","interface"],
	"links": {
		"source": "https://github.com/DumbCaveSpider/GDProfileOverhaul",
		"community": "https://discord.gg/gXcppxTNxC",
		"homepage": "https://arcticwoof.xyz"
	}
}
